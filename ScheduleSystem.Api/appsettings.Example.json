{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "<YOUR_SECRET_KEY_MIN_32_CHARS>",
    "Issuer": "ScheduleSystemApi",
    "Audience": "ScheduleSystemClient"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=<HOST>;Database=<DB_NAME>;User Id=<USER>;Password=<PASSWORD>;TrustServerCertificate=True;"
  }
}
